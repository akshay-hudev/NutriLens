# NutriLens environment variables
# Copy this file to .env and fill in values as needed.

# Optional Gemini description feature. This does not drive nutrition estimates.
GOOGLE_API_KEY=your_api_key_here
NUTRILENS_ENABLE_GEMINI=true
NUTRILENS_GEMINI_MODEL=gemini-2.0-flash

# Food-101 classifier and nutrition table.
NUTRILENS_MODEL_PATH=model_trained_101class.hdf5
NUTRILENS_NUTRITION_CSV=nutrition101.csv

# Upload and geometry assumptions.
NUTRILENS_MAX_IMAGES=5
NUTRILENS_MAX_IMAGE_BYTES=8388608
NUTRILENS_FRAME_DIAMETER_CM=32
NUTRILENS_PLATE_DIAMETER_CM=26
NUTRILENS_DEFAULT_DENSITY=0.85

# Optional reconstruction dependencies.
NUTRILENS_RECON_BACKEND=gsplat
NUTRILENS_ENABLE_COLMAP=false
COLMAP_BIN=colmap
NUTRILENS_ENABLE_GSPLAT=false
NUTRILENS_ENABLE_NERF=false
NUTRILENS_RECON_TIMEOUT_SECONDS=90

# Optional research benchmark hook for MetaFood3D-style data.
NUTRILENS_BENCHMARK_NAME=MetaFood3D-style
NUTRILENS_BENCHMARK_DATA_ROOT=

# USDA FoodData Central API key, only needed to regenerate nutrition101.csv.
USDA_API_KEY=your_usda_api_key_here
